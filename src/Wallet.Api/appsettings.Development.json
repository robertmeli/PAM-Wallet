{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Orleans": "Warning",
      "Orleans.Runtime": "Warning",
      "Orleans.Runtime.Scheduler": "Warning",
      "Orleans.Runtime.Messaging": "Warning",
      "Orleans.Storage": "Warning",
      "Orleans.Telemetry": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "ConnectionStrings": {
    "WalletDb": "Host=localhost;Port=5432;Database=wallet;Username=postgres;Password=postgres"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "Topic": "wallet-events"
  },
  "WalletEventPublishing": {
    "SkipPublishing": false,
    "QueueCapacity": 100000,
    "WorkerCount": 4,
    "OutboxBatchSize": 50,
    "OutboxPollIntervalMs": 500,
    "OutboxBusyPollIntervalMs": 150,
    "OutboxMaxBatchesPerCycle": 1
  }
}
